# ScholarAI backend configuration (SA-008)
# Copy to `.env` and adjust. All values have sane defaults; nothing is required
# for the default local experience.

# --- Storage -----------------------------------------------------------------
# Where all learning spaces, documents, vectors and progress live.
# Default: ~/scholar-ai-data
SCHOLARAI_DATA_DIR=

# --- LLM (Ollama) ------------------------------------------------------------
SCHOLARAI_OLLAMA_BASE_URL=http://localhost:11434
SCHOLARAI_OLLAMA_MODEL=qwen3:8b
# Request timeout for LLM calls, seconds (ingestion LLM passes can be slow).
SCHOLARAI_OLLAMA_TIMEOUT=120

# --- Embeddings --------------------------------------------------------------
SCHOLARAI_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Chunking / retrieval defaults -------------------------------------------
# Sliding-window overlap fraction (0.15–0.25 recommended).
SCHOLARAI_CHUNK_OVERLAP=0.2
# How many chunks to retrieve per query.
SCHOLARAI_TOP_K=5

# --- API ---------------------------------------------------------------------
# Comma-separated allowed origins for the frontend dev server.
SCHOLARAI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
